				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="12" isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA[(new java.text.SimpleDateFormat("yyyy-MM-dd").format($P{tanggalAwal}).equals(new java.text.SimpleDateFormat("yyyy-MM-dd").format($P{tanggalAkhir}))) 
    ? "Tanggal: " + new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id", "ID")).format($P{tanggalAwal}) 
    : "Periode: " + new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id", "ID")).format($P{tanggalAwal}) + " s/d " + new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id", "ID")).format($P{tanggalAkhir})]]></textFieldExpression>
