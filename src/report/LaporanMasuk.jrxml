		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="nama_supplier" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="qty_masuk" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
