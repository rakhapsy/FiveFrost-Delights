		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="nama_pelanggan" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="qty_keluar" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
